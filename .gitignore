# Dados sensíveis
.env

# Bancos de dados (exceto os principais dos projetos)
*.db
!coleta/data/empreendimentos.db
!analise_releases/dados_financeiros.db

# Dados grandes (CSV/Excel) — exceto planilhas do projeto
*.csv
*.xlsx
*.xls
!analise_releases/planilhas/*.xlsx
!analise_releases/schema_sugestao*.xlsx

# Cache e temporários
__pycache__/
*.pyc
.streamlit/secrets.toml

# Caches do projeto
**/geocode_cache.json
**/cep_bairros.json
**/cache_cidades.json
**/mapa_pontos.json

# Downloads, backups, logs
**/downloads/
**/backups/
**/logs/

# HTML gerado
**/mapa_empreendimentos.html

# Docs de mapeamento (debug HTMLs)
**/docs/mapeamento_auto/

# JSON grandes
**/mrv_detalhe.json
**/novas_incorporadoras.json

# Temp e debug
**/temp_pages/
**/pp_page*.png
**/nul

# Claude config
.claude/
